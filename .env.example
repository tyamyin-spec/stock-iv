# Copy this to .env.local and fill in your Supabase project credentials.
# Find these at: https://supabase.com/dashboard/project/_/settings/api
#
# When both are absent, the app runs in offline mode against localStorage
# (single-user, no auth) — useful for local demos.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
